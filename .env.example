# ── 数据路径（二选一） ──

# 方式 A：远程 E 盘（自动挂载 192.168.1.13）
# 默认密码 123456，如需修改设下面两个变量
# SMB_USER=pc
# SMB_PASS=123456

# 方式 B：本地路径（不挂载远程，直接指向本地数据）
FACTOR_DATA_DIR=/path/to/your/factor_implementation_source_data

# ── LLM API（可选，不设则跳过因子审查） ──
# OPENAI_API_KEY=sk-xxx
# OPENAI_API_BASE=https://api.openai.com/v1
