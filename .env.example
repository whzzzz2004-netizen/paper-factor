# =============================================================================
# paper-factor Environment Configuration
# =============================================================================
# Copy this file to .env:  cp .env.example .env
# Or run the setup script:  bash scripts/setup.sh
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Settings (REQUIRED)
# ---------------------------------------------------------------------------
# paper-factor uses LLMs to read papers, generate factor code, and iterate.
# Any OpenAI-compatible API works (OpenAI, DeepSeek, LiteLLM proxy, etc.).

# Model name your LLM provider uses.
#   OpenAI:      gpt-4o, gpt-4-turbo
#   DeepSeek:    deepseek-chat, deepseek-reasoner
#   Qwen:        qwen-plus, qwen-max
#   Claude:      claude-sonnet-4-20250514
CHAT_MODEL=

# Your API key for the LLM provider
OPENAI_API_KEY=

# Base URL for the API endpoint. Leave empty for the provider's default.
#   OpenAI (default):  (leave empty, or https://api.openai.com/v1)
#   DeepSeek:           https://api.deepseek.com/v1
#   DashScope (Qwen):   https://dashscope.aliyuncs.com/compatible-mode/v1
#   LiteLLM proxy:      http://localhost:4000/v1
OPENAI_API_BASE=


# ---------------------------------------------------------------------------
# Embedding Settings (REQUIRED for paper semantic search)
# ---------------------------------------------------------------------------

# Embedding model name
#   OpenAI:       text-embedding-3-small, text-embedding-ada-002
#   DashScope:    text-embedding-v2
#   SiliconFlow:  BAAI/bge-m3
EMBEDDING_MODEL=

# Base URL for the embedding API (may differ from chat base URL)
EMBEDDING_OPENAI_BASE_URL=

# API key for the embedding provider (may differ from chat key)
EMBEDDING_OPENAI_API_KEY=


# ---------------------------------------------------------------------------
# Market Data Provider: Tushare (RECOMMENDED)
# ---------------------------------------------------------------------------
# Tushare provides daily OHLCV, valuation, shares, market value, industry,
# futures data, and minute bars. Get a free token at https://tushare.pro

TUSHARE_TOKEN=

# Number of years of historical data to fetch
TUSHARE_YEARS=1

# Maximum number of stocks in the universe
TUSHARE_MAX_STOCKS=80

# Maximum number of futures contracts
TUSHARE_MAX_FUTURES=20

# Maximum symbols to download minute bars for
TUSHARE_MAX_MINUTE_SYMBOLS=10

# Sleep between API requests in seconds (Tushare has rate limits)
TUSHARE_REQUEST_SLEEP=0.5


# ---------------------------------------------------------------------------
# Alternative Data Provider: JQData (OPTIONAL)
# ---------------------------------------------------------------------------

PAPER_FACTOR_USE_JQDATA=0
JQDATA_USERNAME=
JQDATA_PASSWORD=


# ---------------------------------------------------------------------------
# Factor Execution Backend
# ---------------------------------------------------------------------------
# The `start` command uses Docker (sandboxed, works on any OS).
# The image is built locally from Dockerfile on first run — no registry needed.

# Execution backend: docker | conda | local | auto
FACTOR_CoSTEER_EXECUTION_BACKEND=docker

# Auto-build Docker image from the bundled Dockerfile on first use
FACTOR_CoSTEER_FORCE_DOCKER_BUILD=1


# ---------------------------------------------------------------------------
# LLM / Pipeline Tuning (OPTIONAL)
# ---------------------------------------------------------------------------

# Max retries on LLM API failures
MAX_RETRY=3

# Backend class for LLM calls
BACKEND=rdagent.oai.backend.LiteLLMAPIBackend

# Log full LLM chat content (set to False in production for less noise)
LOG_LLM_CHAT_CONTENT=True

# Skip low-IC repair pass for faster runs
# RDAGENT_PAPER_FACTOR_SKIP_LOW_IC_REPAIR=1

# Fast mode: fewer iterations
# RDAGENT_PAPER_FACTOR_FAST=1
