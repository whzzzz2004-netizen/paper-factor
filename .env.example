# LLM settings
CHAT_MODEL=
OPENAI_API_KEY=
OPENAI_API_BASE=

# Embedding settings
EMBEDDING_MODEL=
EMBEDDING_OPENAI_BASE_URL=
EMBEDDING_OPENAI_API_KEY=

# Optional market data providers.
# Tushare is preferred by `python -m paper_factor_cli.main init --force`
# because it provides broader daily fields such as valuation, shares,
# market value, industry, and futures data.
TUSHARE_TOKEN=
TUSHARE_YEARS=1
TUSHARE_MAX_STOCKS=80
TUSHARE_MAX_FUTURES=20
TUSHARE_MAX_MINUTE_SYMBOLS=10
TUSHARE_REQUEST_SLEEP=0.5

# Optional JQData fallback.
PAPER_FACTOR_USE_JQDATA=0
JQDATA_USERNAME=
JQDATA_PASSWORD=

# Factor execution backend.
DS_CODER_COSTEER_ENV_TYPE=docker
FACTOR_CoSTEER_EXECUTION_BACKEND=docker
FACTOR_CoSTEER_FORCE_DOCKER_BUILD=0
